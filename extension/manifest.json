{
  "manifest_version": 3,
  "name": "ScreenHelp",
  "version": "0.1.0",
  "description": "Your on-screen AI co-pilot — global hotkey to capture and ask anything.",
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "activeTab", "contextMenus"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open ScreenHelp side panel"
  },
  "commands": {
    "answer-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "ScreenHelp — capture and answer now"
    },
    "interview-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "ScreenHelp — interview mode capture"
    },
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "ScreenHelp — open side panel"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
